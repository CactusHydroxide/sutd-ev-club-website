---
import '../styles/global.css';

const { title = 'My Site' } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
    </head>

    <body>
        <header class="site-header">
            <div class="container">
                <h1>Logo</h1>
                <p>SUTD EV Club</p>
                <nav>
                    <a href="/">Home</a>
                    <a href="/KeyActivities">Key Activities</a>
                    <a href="/Projects">Projects</a>
                </nav>
            </div>
        </header>

        <main class="container">
            <!-- Child Component Here -->
            <slot />
        </main>

        <footer class="site-footer">
            <div class="container">
                <p>Footer content footer content</p>
            </div>
        </footer>
    </body>
</html>
